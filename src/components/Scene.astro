---
const scene = Astro.props.scene ?? "scene-01";
---

<img
  data-scene={scene}
  src={`/scenes/en_${scene}.svg`}
  alt={`Scene: ${scene}`}
  class="
    scene-img 
    
    w-auto 
    max-w-[900px] 
    
    h-auto
    max-h-[90vh]

    short:max-h-none
  "
/>



